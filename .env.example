# ─────────────────────────────────────────────────────────────────────
# Tablero Inteligente INT · variables de entorno (copiar a .env)
# Secretos SOLO aquí; nunca en el repo. .env está en .gitignore.
# ─────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL local "internacional" (crear con: createdb internacional).
DATABASE_URL=postgres://localhost:5432/internacional

# Puerto del API Fastify.
API_PORT=5176

# URL del API para el frontend (en dev se usa el proxy de Vite a /api).
VITE_API_URL=

# ── Credenciales opcionales (el panel correspondiente se enciende al pegarlas) ──
# FRED — gratuita: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# YouTube Data API v3 — robustez del live de Bloomberg (degradado keyless si falta).
YOUTUBE_API_KEY=

# ACLED — eventos de conflicto con fatalities (requiere registro + email).
ACLED_API_KEY=
ACLED_EMAIL=
